# ElevenLabs Configuration
# Get your API key at https://elevenlabs.io/app/settings/api-keys
# Create an agent at https://elevenlabs.io/app/conversational-ai

# Option A: Private agent (recommended — keeps API key server-side)
ELEVENLABS_API_KEY=your-api-key-here
ELEVENLABS_AGENT_ID=your-agent-id-here

# Option B: Public agent (no API key needed, agent ID exposed to client)
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-agent-id-here
